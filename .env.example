LOCAL_RPC="ws://127.0.0.1:9944"
DEV_RPC="wss://rpc.hypertensor.app:443"
LIVE_RPC="wss://rpc.hypertensor.app:443"
PHRASE="<your mnemonic phrase here>"

# Linear Agent integration
# Create a Linear OAuth application named "Kettle Local Agent" and keep secrets
# in your local .env only. Never commit real values.
LINEAR_CLIENT_ID=""
LINEAR_CLIENT_SECRET=""
LINEAR_WEBHOOK_SECRET=""
LINEAR_ACCESS_TOKEN=""
LINEAR_REFRESH_TOKEN=""
LINEAR_WORKSPACE_URL="https://linear.app/<workspace>"

# Public HTTPS endpoint exposed by your local webhook service, for example via
# Cloudflare Tunnel. Linear does not accept localhost webhook URLs.
LINEAR_PUBLIC_WEBHOOK_URL="https://<tunnel-host>/webhooks/linear"

# Local Codex/GSD execution defaults.
KETTLE_REPO_DIR="/home/aphex5/work/kettle"
LINEAR_BASE_BRANCH="main"
LINEAR_GSD_MODE="quick"
LINEAR_CODEX_MODEL=""
